<Window x:Class="GUI.Dialogs.RunConfigurationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Run Configuration" 
        Height="500" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <Label Content="Configuration Name:" FontWeight="Bold"/>
            <TextBox x:Name="NameTextBox" Height="25"/>
            
            <Label Content="Description (optional):" FontWeight="Bold" Margin="0,10,0,0"/>
            <TextBox x:Name="DescriptionTextBox" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
        </StackPanel>

        <!-- File Lists -->
        <TabControl Grid.Row="1">
            <TabItem Header="Model Files">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox x:Name="ModelFilesListBox" Grid.Row="0"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                        <Button Content="Add..." Click="AddModelFile_Click" Width="60" Margin="2"/>
                        <Button Content="Remove" Click="RemoveModelFile_Click" Width="60" Margin="2"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Data Files">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox x:Name="DataFilesListBox" Grid.Row="0"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                        <Button Content="Add..." Click="AddDataFile_Click" Width="60" Margin="2"/>
                        <Button Content="Remove" Click="RemoveDataFile_Click" Width="60" Margin="2"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <StackPanel>
                    <Label Content="Settings File (optional):" FontWeight="Bold"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBox x:Name="SettingsFileTextBox" Grid.Column="0" IsReadOnly="True"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Browse..." Click="BrowseSettingsFile_Click" Width="70" Margin="5,0,0,0"/>
                            <Button Content="Clear" Click="ClearSettingsFile_Click" Width="50" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Label Content="Working Directory (optional):" FontWeight="Bold" Margin="0,10,0,0"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBox x:Name="WorkingDirectoryTextBox" Grid.Column="0" IsReadOnly="True"/>
                        <Button Content="Browse..." Grid.Column="1" Click="BrowseWorkingDirectory_Click" Width="70" Margin="5,0,0,0"/>
                    </Grid>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="OK" IsDefault="True" Click="OK_Click" Width="75" Margin="5,0"/>
            <Button Content="Cancel" IsCancel="True" Width="75" Margin="5,0"/>
        </StackPanel>
    </Grid>
</Window>